# Copy to .env before first run:
#   Windows:  copy .env.example .env
#   macOS/Linux:  cp .env.example .env
#
# See README.md → Configuration for profiles and full variable reference.

# ── Ollama (required) ─────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
MODEL_NAME=iKhalid/ALLaM:7b
EMBED_MODEL=nomic-embed-text:latest

# ── Model behavior ────────────────────────────────────────────────────────────
NUM_CTX=4096
TEMPERATURE=0.3
MAX_HISTORY=10

# ── ChromaDB / RAG ────────────────────────────────────────────────────────────
CHROMA_PATH=./db/chroma
COLLECTION_NAME=finance_concepts
DOCS_PATH=./data/documents
PROMPTS_DIR=./prompts

# ── Optional external APIs (leave blank to skip) ───────────────────────────────
# FINNHUB_API_KEY=
# TWELVEDATA_API_KEY=
# NEWS_API_KEY=
# HF_TOKEN=
